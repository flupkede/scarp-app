# Copy this to .env and fill in your key.
# .env is gitignored — never commit the real key.

# DeepInfra API key (default provider — GLM 4.7 Flash)
# Get yours at: https://deepinfra.com/
DEEPINFRA_API_KEY=your-deepinfra-api-key-here

# Optional overrides (defaults shown — change only if switching provider):
# LLM_BASE_URL=https://api.deepinfra.com/v1/openai
# LLM_MODEL=zai-org/GLM-4.7-Flash
# LLM_API_KEY=          # alternative to DEEPINFRA_API_KEY

# CORS (add your SWA domain when deploying):
# CORS_ALLOW_ORIGINS=http://localhost:11001,https://scarp.dsoft.services
