# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

# ── LLM provider ──────────────────────────────────────────────
# Option A: DeepInfra (OpenAI-compatible, default)
LLM_BASE_URL=https://api.deepinfra.com/v1/openai
LLM_MODEL=zai-org/GLM-4.7-Flash
# DEEPINFRA_API_KEY=your-deepinfra-key-here

# Option B: Anthropic (native SDK, tool_use format)
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option C: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here

# The code auto-detects the provider from LLM_BASE_URL:
#   "anthropic" in URL → Anthropic SDK
#   everything else    → OpenAI-compatible SDK

# API key fallback chain (if LLM_API_KEY is not set):
#   LLM_API_KEY → DEEPINFRA_API_KEY → OPENAI_API_KEY → ANTHROPIC_API_KEY

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ALLOW_ORIGINS=http://localhost:11001,http://localhost:5173,http://localhost:4173,https://scarp.dsoft.services

# ── Data ──────────────────────────────────────────────────────
# Optional: path to processed GeoJSON data (defaults to repo data/processed/)
# DATA_DIR=/absolute/path/to/data/processed

# ── Search ────────────────────────────────────────────────────
# Optional: disable LLM search (useful for dev without an API key)
# ENABLE_SEARCH=false
